---
import { getCollection } from 'astro:content';
import CaseStudyLayout from '../../layouts/CaseStudyLayout.astro';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await project.render();
const wordCount = (project.body ?? '').split(/\s+/).filter(Boolean).length;
const readingTime = Math.max(1, Math.ceil(wordCount / 200));

const order = ['serbia-inspire', 'bm-club', 'ecosoul', 'autobaza', 'omoda-espana'];
const allProjects = (await getCollection('projects'))
  .filter(p => !p.data.comingSoon)
  .sort((a, b) => {
    const ai = order.indexOf(a.slug);
    const bi = order.indexOf(b.slug);
    return (ai === -1 ? 999 : ai) - (bi === -1 ? 999 : bi);
  });
const idx = allProjects.findIndex(p => p.slug === project.slug);
const prevProject = idx > 0 ? allProjects[idx - 1] : null;
const nextProject = idx < allProjects.length - 1 ? allProjects[idx + 1] : null;
---

<CaseStudyLayout
  title={project.data.displayTitle ?? project.data.title}
  year={project.data.year}
  tags={project.data.tags}
  liveUrl={project.data.liveUrl}
  readingTime={readingTime}
  prevSlug={prevProject?.slug}
  prevTitle={prevProject?.data.displayTitle ?? prevProject?.data.title}
  nextSlug={nextProject?.slug}
  nextTitle={nextProject?.data.displayTitle ?? nextProject?.data.title}
>
  <Content />
</CaseStudyLayout>
