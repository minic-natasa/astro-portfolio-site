---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Footer from '../components/Footer.astro';
import SideNav from '../components/SideNav.astro';
import WorkPreview from '../components/WorkPreview.astro';

const work = (await getCollection('work')).sort((a, b) => {
  if (a.data.comingSoon && !b.data.comingSoon) return 1;
  if (!a.data.comingSoon && b.data.comingSoon) return -1;
  const yearDiff = (b.data.year ?? 0) - (a.data.year ?? 0);
  if (yearDiff !== 0) return yearDiff;
  return a.data.title.localeCompare(b.data.title);
});

// Exact per-item border removal (last column / last row of each breakpoint's
// grid), computed from the real item count instead of nth-child(3n) math —
// that assumes the total is divisible by the column count, which breaks the
// grid lines whenever it isn't.
function gridBorderClasses(index: number, total: number) {
  const pos = index + 1;
  const mobileCols = 2, desktopCols = 3;
  const mobileLastRowStart  = (Math.ceil(total / mobileCols)  - 1) * mobileCols  + 1;
  const desktopLastRowStart = (Math.ceil(total / desktopCols) - 1) * desktopCols + 1;

  const mobileNoRight  = pos % mobileCols === 0  || pos === total;
  const mobileNoBottom = pos >= mobileLastRowStart;
  const desktopNoRight  = pos % desktopCols === 0 || pos === total;
  const desktopNoBottom = pos >= desktopLastRowStart;

  const right = mobileNoRight
    ? (desktopNoRight ? 'border-r-0' : 'border-r-0 md:border-r')
    : (desktopNoRight ? 'md:border-r-0' : '');
  const bottom = mobileNoBottom
    ? (desktopNoBottom ? 'border-b-0' : 'border-b-0 md:border-b')
    : (desktopNoBottom ? 'md:border-b-0' : '');

  return [right, bottom].filter(Boolean).join(' ');
}
---

<BaseLayout title="projects / naca">
  <SideNav links={[{ href: '/', label: 'home' }, { href: '/cheatsheets', label: 'cheatsheets' }]} />
  <main id="main" tabindex="-1" class="pt-4 md:pt-8 flex-1">
    <div class="max-w-2xl mx-auto px-6">
      <h1 class="text-[28px] font-light tracking-tight mb-8 md:mb-16" data-scramble style="color: var(--text-1);">all work.</h1>
    </div>

    <div class="max-w-5xl mx-auto px-6">
      <div class="grid grid-cols-2 md:grid-cols-3 auto-rows-fr">
        {work.map((item, i) => (
          <div
            class={`group sr flex flex-col justify-between pt-6 px-3 md:px-6 pb-4 border-b border-r ${gridBorderClasses(i, work.length)}`}
            style={`border-color: var(--border); background-color: var(--bg); transition-delay: ${Math.min(i * 50, 300)}ms;`}
            data-preview-title={!item.data.comingSoon ? item.data.title.replace(/\n/g, ' ') : undefined}
            data-preview-year={!item.data.comingSoon ? item.data.year : undefined}
            data-preview-tags={!item.data.comingSoon ? (item.data.tags ?? []).join(',') : undefined}
            data-preview-img={!item.data.comingSoon ? (item.data.image ?? "") : undefined}
          >
            <div class="flex items-start justify-between gap-4">
              <h3
                class="text-[15px] font-normal leading-snug"
                style={`font-family: var(--font-display); color: ${item.data.comingSoon ? 'var(--coming-soon)' : 'var(--text-1)'}; white-space: pre-line;`}
              >
                {item.data.title}
              </h3>
              {item.data.comingSoon && (
                <span class="text-xs border px-2 py-0.5 rounded-sm shrink-0 mt-0.5" style="color: var(--coming-soon); border-color: var(--coming-soon-border);">soon</span>
              )}
              {!item.data.comingSoon && (
                <button class="info-toggle md:hidden shrink-0 mt-0.5" aria-label="Show project details" aria-expanded="false" aria-controls={`info-body-${item.id}`}>
                  <svg width="15" height="15" viewBox="0 0 15 15" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <circle cx="7.5" cy="7.5" r="6.5" stroke="currentColor" stroke-width="1.1"/>
                    <line x1="7.5" y1="7" x2="7.5" y2="10.5" stroke="currentColor" stroke-width="1.1" stroke-linecap="round"/>
                    <circle cx="7.5" cy="4.8" r="0.65" fill="currentColor"/>
                  </svg>
                </button>
              )}
            </div>

            {!item.data.comingSoon && (
              <div id={`info-body-${item.id}`} class="info-body mt-7 mb-1 opacity-0 md:opacity-0 pointer-events-none md:pointer-events-auto md:group-hover:opacity-100 transition-opacity duration-300">
                {item.data.tags && item.data.tags.length > 0 && (
                  <div class="flex gap-1 md:gap-1.5 flex-wrap mb-5">
                    {item.data.tags.map((tag) => (
                      <span
                        class="text-[10px] md:text-xs border px-1.5 md:px-2 py-0.5 rounded-sm"
                        style="color: var(--text-3); border-color: var(--border);"
                      >
                        {tag}
                      </span>
                    ))}
                  </div>
                )}
                <div class="flex flex-col gap-1.5 md:flex-row md:items-center md:justify-between md:gap-0">
                  {item.data.year && (
                    <time class="text-xs tabular-nums" datetime={String(item.data.year)} style="color: var(--text-3);">{item.data.year}</time>
                  )}
                  <div class="flex flex-row justify-between md:justify-start md:gap-3 md:ml-auto">
                    {item.data.caseStudySlug && (
                      <a href={`/case-studies/${item.data.caseStudySlug}`} class="text-xs link-accent">
                        case study →
                      </a>
                    )}
                    {item.data.liveUrl && (
                      <a href={item.data.liveUrl} target="_blank" rel="noopener noreferrer" class="text-xs link-accent">
                        see live ↗
                      </a>
                    )}
                    {item.data.altUrl && (
                      <a href={item.data.altUrl} target="_blank" rel="noopener noreferrer" class="text-xs link-accent">
                        {item.data.altLabel ?? 'alt'} ↗
                      </a>
                    )}
                  </div>
                </div>
              </div>
            )}
          </div>
        ))}
      </div>
    </div>

    <div class="max-w-2xl mx-auto px-6">
      <Footer />
    </div>
  </main>

  <!-- Hover preview -->
  <WorkPreview />

  <style>
    /* Mobile info toggle */
    .info-toggle.is-active {
      color: var(--accent);
    }
    @media (max-width: 767px) {
      .info-toggle {
        background: transparent;
        border: none;
        padding: 2px;
        cursor: pointer;
        color: var(--text-3);
        display: flex;
        align-items: center;
        justify-content: center;
        transition: color 0.2s ease;
      }
      .info-body.is-open {
        opacity: 1 !important;
        pointer-events: auto !important;
      }
    }
  </style>

  <script>
    document.addEventListener('astro:page-load', () => {
      // Mobile info toggle
      document.querySelectorAll<HTMLElement>('.info-toggle').forEach(btn => {
        btn.addEventListener('click', (e) => {
          e.stopPropagation();
          const card = btn.closest<HTMLElement>('[data-preview-title]');
          if (!card) return;
          const body = card.querySelector<HTMLElement>('.info-body');
          if (!body) return;
          const isOpen = body.classList.toggle('is-open');
          btn.classList.toggle('is-active', isOpen);
          btn.setAttribute('aria-expanded', String(isOpen));
        });
      });
    });
  </script>
</BaseLayout>
