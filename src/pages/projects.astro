---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Footer from '../components/Footer.astro';
import SideNav from '../components/SideNav.astro';

const work = (await getCollection('work')).sort((a, b) => {
  if (a.data.comingSoon && !b.data.comingSoon) return 1;
  if (!a.data.comingSoon && b.data.comingSoon) return -1;
  const yearDiff = (b.data.year ?? 0) - (a.data.year ?? 0);
  if (yearDiff !== 0) return yearDiff;
  return a.data.title.localeCompare(b.data.title);
});
---

<BaseLayout title="projects / naca">
  <SideNav links={[{ href: '/', label: 'home' }, { href: '/cheatsheets', label: 'cheatsheets' }]} />
  <main class="pt-4 md:pt-8 pb-24">
    <div class="max-w-2xl mx-auto px-6">
      <h1 class="text-[28px] font-light tracking-tight mb-8 md:mb-16" data-scramble style="color: var(--text-1);">all work.</h1>
    </div>

    <div class="max-w-5xl mx-auto px-0 md:px-6">
      <div class="grid grid-cols-2 md:grid-cols-3">
        {work.map((item, i) => (
          <div
            class="group sr flex flex-col justify-between pt-6 px-3 md:px-6 pb-4 border-b border-r [&:nth-child(2n)]:border-r-0 md:[&:nth-child(2n)]:border-r md:[&:nth-child(3n)]:border-r-0 [&:nth-last-child(-n+2)]:border-b-0 md:[&:nth-last-child(-n+2)]:border-b md:[&:nth-last-child(-n+3)]:border-b-0"
            style={`border-color: var(--border); background-color: var(--bg); transition-delay: ${Math.min(i * 50, 300)}ms;`}
            data-preview-title={!item.data.comingSoon ? item.data.title.replace(/\n/g, ' ') : undefined}
            data-preview-year={!item.data.comingSoon ? item.data.year : undefined}
            data-preview-tags={!item.data.comingSoon ? (item.data.tags ?? []).join(',') : undefined}
            data-preview-img={!item.data.comingSoon ? "" : undefined}
          >
            <div class="flex items-start justify-between gap-4">
              <h3
                class="text-[15px] font-normal leading-snug"
                style={`font-family: 'Zalando Sans Expanded', sans-serif; color: ${item.data.comingSoon ? 'var(--coming-soon)' : 'var(--text-1)'}; white-space: pre-line;`}
              >
                {item.data.title}
              </h3>
              {item.data.comingSoon && (
                <span class="text-xs border px-2 py-0.5 rounded-sm shrink-0 mt-0.5" style="color: var(--coming-soon); border-color: var(--coming-soon-border);">soon</span>
              )}
              {!item.data.comingSoon && (
                <button class="info-toggle md:hidden shrink-0 mt-0.5" aria-label="Show project details" aria-expanded="false">
                  <svg width="15" height="15" viewBox="0 0 15 15" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <circle cx="7.5" cy="7.5" r="6.5" stroke="currentColor" stroke-width="1.1"/>
                    <line x1="7.5" y1="7" x2="7.5" y2="10.5" stroke="currentColor" stroke-width="1.1" stroke-linecap="round"/>
                    <circle cx="7.5" cy="4.8" r="0.65" fill="currentColor"/>
                  </svg>
                </button>
              )}
            </div>

            {!item.data.comingSoon && (
              <div class="info-body mt-7 mb-1 opacity-0 md:opacity-0 pointer-events-none md:pointer-events-auto md:group-hover:opacity-100 transition-opacity duration-300">
                {item.data.tags && item.data.tags.length > 0 && (
                  <div class="flex gap-1 md:gap-1.5 flex-wrap mb-5">
                    {item.data.tags.map((tag) => (
                      <span
                        class="text-[10px] md:text-xs border px-1.5 md:px-2 py-0.5 rounded-sm"
                        style="color: var(--text-3); border-color: var(--border);"
                      >
                        {tag}
                      </span>
                    ))}
                  </div>
                )}
                <div class="flex flex-col gap-1.5 md:flex-row md:items-center md:justify-between md:gap-0">
                  {item.data.year && (
                    <span class="text-xs tabular-nums" style="color: var(--text-3);">{item.data.year}</span>
                  )}
                  <div class="flex flex-col gap-1.5 md:flex-row md:gap-3 md:ml-auto">
                    {item.data.caseStudySlug && (
                      <a href={`/case-studies/${item.data.caseStudySlug}`} class="text-xs link-accent">
                        case study →
                      </a>
                    )}
                    {item.data.liveUrl && (
                      <a href={item.data.liveUrl} target="_blank" rel="noopener noreferrer" class="text-xs link-accent">
                        see live ↗
                      </a>
                    )}
                    {item.data.altUrl && (
                      <a href={item.data.altUrl} target="_blank" rel="noopener noreferrer" class="text-xs link-accent">
                        {item.data.altLabel ?? 'alt'} ↗
                      </a>
                    )}
                  </div>
                </div>
              </div>
            )}
          </div>
        ))}
      </div>
    </div>

    <div class="max-w-2xl mx-auto px-6">
      <Footer />
    </div>
  </main>

  <!-- Hover preview -->
  <div id="work-preview" aria-hidden="true">
    <div id="wp-image">
      <span id="wp-image-label"></span>
    </div>
    <div id="wp-meta">
      <p id="wp-title"></p>
      <p id="wp-year"></p>
    </div>
  </div>

  <style>
    #work-preview {
      position: fixed;
      pointer-events: none;
      z-index: 200;
      background: var(--bg);
      border: 1px solid var(--border-h);
      border-radius: 4px;
      width: 220px;
      overflow: hidden;
      opacity: 0;
      transform: translateY(6px) scale(0.97);
      transition: opacity 0.18s ease, transform 0.18s ease;
    }
    #work-preview.is-visible {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
    #wp-image {
      width: 100%;
      aspect-ratio: 16/9;
      background: var(--border);
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
    }
    #wp-image img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }
    #wp-image-label {
      font-family: 'Zalando Sans Expanded', sans-serif;
      font-size: 10px;
      letter-spacing: 0.08em;
      color: var(--text-3);
    }
    #wp-meta {
      padding: 10px 12px;
    }
    #wp-title {
      font-family: 'Zalando Sans Expanded', sans-serif;
      font-size: 12px;
      font-weight: 300;
      color: var(--text-1);
      line-height: 1.4;
    }
    #wp-year {
      font-size: 11px;
      color: var(--text-3);
      margin-top: 3px;
      font-variant-numeric: tabular-nums;
    }
    @media (max-width: 768px) {
      #work-preview { display: none; }
    }

    /* Mobile info toggle */
    .info-toggle.is-active {
      color: var(--accent);
    }
    @media (max-width: 767px) {
      .info-toggle {
        background: transparent;
        border: none;
        padding: 2px;
        cursor: pointer;
        color: var(--text-3);
        display: flex;
        align-items: center;
        justify-content: center;
        transition: color 0.2s ease;
      }
      .info-body.is-open {
        opacity: 1 !important;
        pointer-events: auto !important;
      }
    }
  </style>

  <script>
    document.addEventListener('astro:page-load', () => {
      // Equalize all card heights to the tallest card (desktop only)
      if (window.innerWidth >= 768) {
        const grid = document.querySelector<HTMLElement>('.grid.grid-cols-2');
        if (grid) {
          const cards = Array.from(grid.children) as HTMLElement[];
          cards.forEach(c => c.style.minHeight = '');
          const maxH = Math.max(...cards.map(c => c.offsetHeight));
          cards.forEach(c => c.style.minHeight = maxH + 'px');
        }
      }

      // Mobile info toggle
      document.querySelectorAll<HTMLElement>('.info-toggle').forEach(btn => {
        btn.addEventListener('click', (e) => {
          e.stopPropagation();
          const card = btn.closest<HTMLElement>('[data-preview-title]');
          if (!card) return;
          const body = card.querySelector<HTMLElement>('.info-body');
          if (!body) return;
          const isOpen = body.classList.toggle('is-open');
          btn.classList.toggle('is-active', isOpen);
          btn.setAttribute('aria-expanded', String(isOpen));
        });
      });

      const preview    = document.getElementById('work-preview');
      const wpTitle    = document.getElementById('wp-title');
      const wpYear     = document.getElementById('wp-year');
      const wpImage    = document.getElementById('wp-image');
      const wpImageLbl = document.getElementById('wp-image-label');
      if (!preview || !wpTitle || !wpYear || !wpImage || !wpImageLbl) return;
      if (!window.matchMedia('(hover: hover)').matches) return;

      let cursorX = 0, cursorY = 0;

      document.addEventListener('mousemove', (e) => {
        cursorX = e.clientX;
        cursorY = e.clientY;
        if (preview.classList.contains('is-visible')) {
          const x = Math.min(cursorX + 20, window.innerWidth - 240);
          const y = Math.max(cursorY - preview.offsetHeight - 12, 10);
          preview.style.left = x + 'px';
          preview.style.top  = y + 'px';
        }
      });

      document.querySelectorAll<HTMLElement>('[data-preview-title]').forEach(card => {
        card.addEventListener('mouseenter', () => {
          const title   = card.dataset.previewTitle ?? '';
          const year    = card.dataset.previewYear  ?? '';
          const imgSrc  = card.dataset.previewImg   ?? '';

          wpTitle.textContent = title;
          wpYear.textContent  = year;

          // Image or placeholder
          const existing = wpImage.querySelector('img');
          if (existing) existing.remove();
          if (imgSrc) {
            const img = document.createElement('img');
            img.src = imgSrc;
            img.alt = title;
            wpImage.insertBefore(img, wpImageLbl);
            wpImageLbl.style.display = 'none';
          } else {
            wpImageLbl.textContent = title;
            wpImageLbl.style.display = '';
          }

          const x = Math.min(cursorX + 20, window.innerWidth - 240);
          const y = Math.max(cursorY - preview.offsetHeight - 12, 10);
          preview.style.left = x + 'px';
          preview.style.top  = y + 'px';
          preview.classList.add('is-visible');
        });

        card.addEventListener('mouseleave', () => {
          preview.classList.remove('is-visible');
        });
      });
    });
  </script>
</BaseLayout>
