---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Footer from '../components/Footer.astro';

const work = (await getCollection('work')).sort((a, b) => {
  if (a.data.comingSoon && !b.data.comingSoon) return 1;
  if (!a.data.comingSoon && b.data.comingSoon) return -1;
  const yearDiff = (b.data.year ?? 0) - (a.data.year ?? 0);
  if (yearDiff !== 0) return yearDiff;
  return a.data.title.localeCompare(b.data.title);
});
---

<BaseLayout title="projects — naca">
  <main class="pt-8 pb-24">
    <div class="max-w-2xl mx-auto px-6">
      <h1 class="text-[28px] font-light tracking-tight mb-16" style="color: var(--text-1);">all work.</h1>
    </div>

    <div class="max-w-5xl mx-auto px-6">
      <div class="grid grid-cols-2 md:grid-cols-3">
        {work.map((item) => (
          <div
            class="group flex flex-col justify-between p-6 min-h-[140px] border-b border-r [&:nth-child(2n)]:border-r-0 md:[&:nth-child(2n)]:border-r md:[&:nth-child(3n)]:border-r-0 [&:nth-last-child(-n+2)]:border-b-0 md:[&:nth-last-child(-n+3)]:border-b-0"
            style="border-color: var(--border); background-color: var(--bg);"
          >
            <div class="flex items-start justify-between gap-2">
              <h3
                class="text-[18px] font-normal leading-snug"
                style={`font-family: 'Zalando Sans Expanded', sans-serif; color: ${item.data.comingSoon ? 'var(--coming-soon)' : 'var(--text-1)'}; white-space: pre-line;`}
              >
                {item.data.title}
              </h3>
              {item.data.comingSoon && (
                <span class="text-xs border px-2 py-0.5 rounded-sm shrink-0 mt-0.5" style="color: var(--coming-soon); border-color: var(--coming-soon-border);">{item.data.year}</span>
              )}
            </div>

            {!item.data.comingSoon && (
              <div class="mt-4 opacity-0 group-hover:opacity-100 transition-opacity duration-300">
                {item.data.tags && item.data.tags.length > 0 && (
                  <div class="flex gap-1.5 flex-wrap mb-3">
                    {item.data.tags.map((tag) => (
                      <span
                        class="text-xs border px-2 py-0.5 rounded-sm"
                        style="color: var(--text-3); border-color: var(--border);"
                      >
                        {tag}
                      </span>
                    ))}
                  </div>
                )}
                <div class="flex items-center justify-between">
                  {item.data.year && (
                    <span class="text-xs tabular-nums" style="color: var(--text-3);">{item.data.year}</span>
                  )}
                  <div class="flex gap-3 ml-auto">
                    {item.data.caseStudySlug && (
                      <a
                        href={`/case-studies/${item.data.caseStudySlug}`}
                        class="text-xs"
                        style="color: var(--accent);"
                      >
                        case study →
                      </a>
                    )}
                    {item.data.liveUrl && (
                      <a
                        href={item.data.liveUrl}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="text-xs"
                        style="color: var(--accent);"
                      >
                        see live ↗
                      </a>
                    )}
                    {item.data.altUrl && (
                      <a
                        href={item.data.altUrl}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="text-xs"
                        style="color: var(--accent);"
                      >
                        {item.data.altLabel ?? 'alt'} ↗
                      </a>
                    )}
                  </div>
                </div>
              </div>
            )}
          </div>
        ))}
      </div>
    </div>

    <div class="max-w-2xl mx-auto px-6">
      <Footer />
    </div>
  </main>
</BaseLayout>
