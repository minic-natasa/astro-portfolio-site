---
import { ViewTransitions } from 'astro:transitions';
import Analytics from '@vercel/analytics/astro';
import SpeedInsights from '@vercel/speed-insights/astro';
import Navbar from '../components/Navbar.astro';
import MobileNav from '../components/MobileNav.astro';

interface Props {
  title?: string;
  description?: string;
  showNav?: boolean;
}

const {
  title = 'naca',
  description = 'portfolio of Nataša Minić, web developer. fast, clean and maintainable. the kind of work that holds up.',
  showNav = true,
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Prevent theme flash -->
    <script is:inline>
      const saved = localStorage.getItem('theme');
      const theme = saved ?? 'dark';
      document.documentElement.classList.remove('dark', 'light');
      document.documentElement.classList.add(theme);
    </script>

    <meta name="author" content="Nataša Minić" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Onest:wght@100..900&family=Zalando+Sans+Expanded:ital,wght@0,200..900;1,200..900&display=swap"
      rel="stylesheet"
    />
    <Analytics />
    <ViewTransitions />
  </head>
  <body style="background-color: var(--bg); color: var(--text-1); font-family: 'Onest', system-ui, sans-serif; font-weight: 300;" class="antialiased min-h-screen">
    {showNav && <Navbar />}
    <slot />
    <MobileNav />
    <SpeedInsights />
  </body>
</html>

<style is:global>
  /* Dark theme (default) */
  html.dark {
    --bg: #181818;
    --text-1: #F7F6F6;
    --text-2: #8E8E93;
    --text-3: #636366;
    --accent: #5B8DB8;
    --accent-h: #80AECE;
    --accent-d: #1A2430;
    --border: #2A2A2A;
    --border-h: #383838;
    --code-bg: #1F1F1F;
    --selection-bg: #1A2430;
    --selection-text: #F7F6F6;
    --coming-soon: #4A7A9B;
    --coming-soon-border: #1A2D3E;
  }

  /* Light theme */
  html.light {
    --bg: #F7F6F6;
    --text-1: #121212;
    --text-2: #3D3D40;
    --text-3: #8E8E93;
    --accent: #2E6B9E;
    --accent-h: #5B8DB8;
    --accent-d: #D0E4F0;
    --border: #D9D9D9;
    --border-h: #C0C0C4;
    --code-bg: #FFFFFF;
    --selection-bg: #D0E4F0;
    --selection-text: #121212;
    --coming-soon: #2E6B9E;
    --coming-soon-border: #C0DCF0;
  }

  ::selection {
    background-color: var(--selection-bg);
    color: var(--selection-text);
  }

  html {
    scroll-behavior: smooth;
  }

  h1 {
    font-family: 'Zalando Sans Expanded', sans-serif;
  }

  *, *::before, *::after {
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    transition: background-color 0.4s ease, color 0.4s ease, border-color 0.4s ease;
  }

  @keyframes fade-in {
    from { opacity: 0; }
  }
  @keyframes fade-out {
    to { opacity: 0; }
  }
  ::view-transition-old(root) {
    animation: 350ms ease both fade-out;
  }
  ::view-transition-new(root) {
    animation: 350ms ease both fade-in;
  }
</style>
