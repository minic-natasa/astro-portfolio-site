---
import BaseLayout from './BaseLayout.astro';
import Footer from '../components/Footer.astro';
import SideNav from '../components/SideNav.astro';

interface Props {
  title: string;
  slug?: string;
  image?: string;
  year: number;
  tags: string[];
  liveUrl?: string;
  readingTime?: number;
  prevSlug?: string;
  prevTitle?: string;
  nextSlug?: string;
  nextTitle?: string;
}

const { title, slug, image, year, tags, liveUrl, readingTime, prevSlug, prevTitle, nextSlug, nextTitle } = Astro.props;
---

<BaseLayout title={`${title} / naca`}>
  <div id="reading-progress" aria-hidden="true"></div>
  <SideNav links={[{ href: '/', label: 'home' }, { href: '/projects', label: 'projects' }, { href: '/cheatsheets', label: 'cheatsheets' }]} />
  <main id="main" tabindex="-1" class="w-full max-w-2xl mx-auto px-6 pt-4 md:pt-6 flex-1">
    <a
      href="/"
      id="back-link"
      class="back-link text-sm tracking-wide mb-8 inline-block cursor-pointer"
    >
      ← go back
    </a>

    <article>
      <header class="mb-12">
        <h1 class="text-[28px] font-light tracking-tight mb-3" style="color: var(--text-1);" transition:name={slug ? `cs-title-${slug}` : undefined}>{title}</h1>
        <div class="flex items-center gap-4 flex-wrap">
          <time class="text-base" datetime={String(year)} style="color: var(--text-3);">{year}</time>
          {readingTime && (
            <span class="text-base" style="color: var(--text-3);">{readingTime} min read</span>
          )}
          <div class="flex gap-2 flex-wrap">
            {tags.map((tag) => (
              <span class="text-xs border px-2 py-0.5 rounded-sm" style="color: var(--text-3); border-color: var(--border);">
                {tag}
              </span>
            ))}
          </div>
          {liveUrl && (
            <a href={liveUrl} target="_blank" rel="noopener noreferrer" class="text-xs link-accent shrink-0">see live ↗</a>
          )}
        </div>
      </header>

      {image ? (
        <div class="w-full rounded-sm mb-12 overflow-hidden" style="aspect-ratio: 16/9; background: var(--border);">
          <img
            src={image}
            alt={`${title} screenshot`}
            width="1280"
            height="720"
            fetchpriority="high"
            style="width: 100%; height: 100%; object-fit: cover; display: block;"
          />
        </div>
      ) : (
        <div class="w-full rounded-sm mb-12 overflow-hidden" style="aspect-ratio: 16/9; background: var(--border); display: flex; align-items: center; justify-content: center;">
          <span style="font-family: var(--font-display); font-size: 12px; letter-spacing: 0.1em; color: var(--text-3);">hero screenshot</span>
        </div>
      )}

      <div class="prose prose-base max-w-none"
        style="
          --tw-prose-body: var(--text-2);
          --tw-prose-headings: var(--text-1);
          --tw-prose-links: var(--text-1);
          --tw-prose-bold: var(--text-1);
          --tw-prose-counters: var(--text-3);
          --tw-prose-bullets: var(--accent);
          --tw-prose-hr: var(--border);
          --tw-prose-quotes: var(--text-2);
          --tw-prose-code: var(--text-1);
          --tw-prose-pre-code: var(--text-1);
          --tw-prose-pre-bg: var(--code-bg);
        "
      >
        <slot />
      </div>
    </article>

    {(prevSlug || nextSlug) && (
      <nav class="flex justify-between items-center pt-10 border-t text-sm" style="border-color: var(--border); margin-top: 4rem;">
        <div>
          {prevSlug && (
            <a href={`/case-studies/${prevSlug}`} class="link-accent flex flex-col gap-0.5">
              <span style="color: var(--text-3); font-size: 11px;">← previous</span>
              <span>{prevTitle}</span>
            </a>
          )}
        </div>
        <div class="text-right">
          {nextSlug && (
            <a href={`/case-studies/${nextSlug}`} class="link-accent flex flex-col gap-0.5 items-end">
              <span style="color: var(--text-3); font-size: 11px;">next →</span>
              <span>{nextTitle}</span>
            </a>
          )}
        </div>
      </nav>
    )}

    <Footer />
  </main>
</BaseLayout>

<style>
  #reading-progress {
    position: fixed;
    top: 0;
    left: 0;
    height: 2px;
    width: 0%;
    background: var(--accent);
    z-index: 9995;
    transition: width 0.1s linear;
  }

  @media (max-width: 768px) {
    #reading-progress {
      height: 3px;
      transition: none;
    }
  }

  /* Case study body sections — fade/rise in as they scroll into view */
  .cs-reveal {
    opacity: 0;
    transform: translateY(16px);
    transition: opacity 0.6s ease, transform 0.6s ease;
  }
  .cs-reveal.cs-reveal-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .back-link {
    color: var(--accent);
    transition: color 0.2s ease;
  }
  .back-link:hover,
  .back-link:focus-visible {
    color: var(--accent-h);
  }
</style>

<script>
  function initSectionReveal() {
    const prose = document.querySelector<HTMLElement>('.prose');
    if (!prose) return;
    const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    // Group direct children into per-section wrappers, split at each <h2>
    const children = Array.from(prose.children) as HTMLElement[];
    let current: HTMLElement | null = null;
    const sections: HTMLElement[] = [];
    children.forEach(child => {
      if (child.tagName === 'H2' || !current) {
        current = document.createElement('div');
        current.className = 'cs-reveal';
        prose.insertBefore(current, child);
        sections.push(current);
      }
      current!.appendChild(child);
    });

    if (reducedMotion) {
      sections.forEach(s => s.classList.add('cs-reveal-visible'));
      return;
    }

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('cs-reveal-visible');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.08, rootMargin: '0px 0px -20px 0px' });

    sections.forEach(s => observer.observe(s));
  }

  document.addEventListener('astro:page-load', () => {
    const back = document.getElementById('back-link');
    back?.addEventListener('click', (e) => {
      e.preventDefault();
      if (history.length > 1) history.back();
      else window.location.href = '/';
    });

    initSectionReveal();

    const bar = document.getElementById('reading-progress');
    if (!bar) return;
    function update() {
      const scrollTop  = window.scrollY;
      const docHeight  = document.documentElement.scrollHeight - window.innerHeight;
      bar.style.width  = docHeight > 0 ? (scrollTop / docHeight * 100) + '%' : '0%';
    }
    window.addEventListener('scroll', update, { passive: true });
    update();
  });
</script>

<style is:global>
  .prose h2,
  .prose h3,
  .prose h4 {
    font-family: var(--font-display);
    font-weight: 300;
  }

  @media (min-width: 768px) {
    .prose h2 { font-size: 1.1rem; }
    .prose h3 { font-size: 1rem; }
    .prose h4 { font-size: 0.9rem; }
  }
</style>
