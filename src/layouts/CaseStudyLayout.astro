---
import BaseLayout from './BaseLayout.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  year: number;
  tags: string[];
}

const { title, year, tags } = Astro.props;
---

<BaseLayout title={`${title} — Nataša Minić`}>
  <main class="max-w-2xl mx-auto px-6 py-20">
    <a
      href="/"
      class="text-xs uppercase tracking-widest text-[#482A32] hover:text-[#95757F] transition-colors duration-200 mb-16 inline-block"
    >
      ← Back
    </a>

    <article>
      <header class="mb-12">
        <h1 class="text-2xl font-light text-white tracking-tight mb-3">{title}</h1>
        <div class="flex items-center gap-4 flex-wrap">
          <span class="text-[#95757F] text-sm">{year}</span>
          <div class="flex gap-2 flex-wrap">
            {tags.map((tag) => (
              <span class="text-[#95757F] text-xs border border-[#36151E] px-2 py-0.5 rounded-sm">
                {tag}
              </span>
            ))}
          </div>
        </div>
      </header>

      <div class="prose prose-sm max-w-none
        prose-headings:text-[#EFF1F3] prose-headings:font-light prose-headings:tracking-tight
        prose-p:text-[#EFF1F3] prose-p:leading-relaxed
        prose-strong:text-[#EFF1F3] prose-strong:font-medium
        prose-a:text-[#EFF1F3] prose-a:underline prose-a:decoration-[#482A32] hover:prose-a:decoration-[#EFF1F3]
        prose-code:text-[#EFF1F3] prose-code:bg-[#0e0e0e] prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded prose-code:text-xs prose-code:font-normal prose-code:before:content-none prose-code:after:content-none
        prose-pre:bg-[#0e0e0e] prose-pre:border prose-pre:border-[#1e1e1e] prose-pre:rounded-none
        prose-hr:border-[#1e1e1e]
        prose-li:text-[#EFF1F3]
        prose-ul:marker:text-[#482A32]
      ">
        <slot />
      </div>
    </article>

    <Footer />
  </main>
</BaseLayout>
