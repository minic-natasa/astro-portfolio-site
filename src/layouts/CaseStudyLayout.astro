---
import BaseLayout from './BaseLayout.astro';
import Footer from '../components/Footer.astro';
import SideNav from '../components/SideNav.astro';

interface Props {
  title: string;
  year: number;
  tags: string[];
}

const { title, year, tags } = Astro.props;
---

<BaseLayout title={`${title} — naca`}>
  <SideNav links={[{ href: '/', label: 'home' }, { href: '/projects', label: 'projects' }, { href: '/cheatsheets', label: 'cheatsheets' }]} />
  <main class="max-w-2xl mx-auto px-6 pt-6 pb-20">
    <a
      href="/"
      class="text-base uppercase tracking-widest transition-colors duration-200 mb-8 inline-block"
      style="color: var(--accent);"
      onmouseover="this.style.color='var(--accent-h)'"
      onmouseout="this.style.color='var(--accent)'"
    >
      ← Back
    </a>

    <article>
      <header class="mb-12">
        <h1 class="text-[28px] font-light tracking-tight mb-3" style="color: var(--text-1);">{title}</h1>
        <div class="flex items-center gap-4 flex-wrap">
          <span class="text-base" style="color: var(--text-3);">{year}</span>
          <div class="flex gap-2 flex-wrap">
            {tags.map((tag) => (
              <span class="text-base border px-2 py-0.5 rounded-sm" style="color: var(--text-3); border-color: var(--accent-d);">
                {tag}
              </span>
            ))}
          </div>
        </div>
      </header>

      <div class="w-full rounded-sm mb-12 overflow-hidden" style="aspect-ratio: 16/9; background: var(--border); display: flex; align-items: center; justify-content: center;">
        <span style="font-family: 'Zalando Sans Expanded', sans-serif; font-size: 12px; letter-spacing: 0.1em; color: var(--text-3);">hero screenshot</span>
      </div>

      <div class="prose prose-base max-w-none"
        style="
          --tw-prose-body: var(--text-2);
          --tw-prose-headings: var(--text-1);
          --tw-prose-links: var(--text-1);
          --tw-prose-bold: var(--text-1);
          --tw-prose-counters: var(--text-3);
          --tw-prose-bullets: var(--accent);
          --tw-prose-hr: var(--border);
          --tw-prose-quotes: var(--text-2);
          --tw-prose-code: var(--text-1);
          --tw-prose-pre-code: var(--text-1);
          --tw-prose-pre-bg: var(--code-bg);
        "
      >
        <slot />
      </div>
    </article>

    <Footer />
  </main>
</BaseLayout>
