---
import BaseLayout from './BaseLayout.astro';
import Footer from '../components/Footer.astro';
import SideNav from '../components/SideNav.astro';

interface Props {
  title: string;
  year: number;
  tags: string[];
}

const { title, year, tags } = Astro.props;
---

<BaseLayout title={`${title} / naca`}>
  <div id="reading-progress" aria-hidden="true"></div>
  <SideNav links={[{ href: '/', label: 'home' }, { href: '/projects', label: 'projects' }, { href: '/cheatsheets', label: 'cheatsheets' }]} />
  <main class="max-w-2xl mx-auto px-6 pt-4 md:pt-6 pb-20">
    <a
      href="/"
      onclick="event.preventDefault(); history.length > 1 ? history.back() : window.location.href = '/'"
      class="back-link text-sm tracking-wide mb-8 inline-block cursor-pointer"
    >
      ← go back
    </a>

    <article>
      <header class="mb-12">
        <h1 class="text-[28px] font-light tracking-tight mb-3" data-scramble style="color: var(--text-1);">{title}</h1>
        <div class="flex items-center gap-4 flex-wrap">
          <span class="text-base" style="color: var(--text-3);">{year}</span>
          <div class="flex gap-2 flex-wrap">
            {tags.map((tag) => (
              <span class="text-base border px-2 py-0.5 rounded-sm" style="color: var(--text-3); border-color: var(--accent-d);">
                {tag}
              </span>
            ))}
          </div>
        </div>
      </header>

      <div class="w-full rounded-sm mb-12 overflow-hidden" style="aspect-ratio: 16/9; background: var(--border); display: flex; align-items: center; justify-content: center;">
        <span style="font-family: 'Zalando Sans Expanded', sans-serif; font-size: 12px; letter-spacing: 0.1em; color: var(--text-3);">hero screenshot</span>
      </div>

      <div class="prose prose-base max-w-none"
        style="
          --tw-prose-body: var(--text-2);
          --tw-prose-headings: var(--text-1);
          --tw-prose-links: var(--text-1);
          --tw-prose-bold: var(--text-1);
          --tw-prose-counters: var(--text-3);
          --tw-prose-bullets: var(--accent);
          --tw-prose-hr: var(--border);
          --tw-prose-quotes: var(--text-2);
          --tw-prose-code: var(--text-1);
          --tw-prose-pre-code: var(--text-1);
          --tw-prose-pre-bg: var(--code-bg);
        "
      >
        <slot />
      </div>
    </article>

    <Footer />
  </main>
</BaseLayout>

<style>
  #reading-progress {
    position: fixed;
    top: 0;
    left: 0;
    height: 2px;
    width: 0%;
    background: var(--accent);
    z-index: 9999;
    transition: width 0.1s linear;
  }

  @media (max-width: 768px) {
    #reading-progress {
      height: 3px;
      transition: none;
    }
  }

  .back-link {
    color: var(--accent);
    transition: color 0.2s ease;
  }
  .back-link:hover,
  .back-link:focus-visible {
    color: var(--accent-h);
  }
</style>

<script>
  document.addEventListener('astro:page-load', () => {
    const bar = document.getElementById('reading-progress');
    if (!bar) return;
    function update() {
      const scrollTop  = window.scrollY;
      const docHeight  = document.documentElement.scrollHeight - window.innerHeight;
      bar.style.width  = docHeight > 0 ? (scrollTop / docHeight * 100) + '%' : '0%';
    }
    window.addEventListener('scroll', update, { passive: true });
    update();
  });
</script>

<style is:global>
  .prose h2,
  .prose h3,
  .prose h4 {
    font-family: 'Zalando Sans Expanded', sans-serif;
    font-weight: 300;
  }

  @media (min-width: 768px) {
    .prose h2 { font-size: 1.1rem; }
    .prose h3 { font-size: 1rem; }
    .prose h4 { font-size: 0.9rem; }
  }
</style>
