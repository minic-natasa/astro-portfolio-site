---
interface Props {
  slug: string;
  title: string;
  description: string;
  tags: string[];
  year: number;
  comingSoon?: boolean;
}

const { slug, title, description, tags, year, comingSoon = false } = Astro.props;
---

{comingSoon ? (
  <div class="block border-t border-[#1e1e1e] py-7">
    <div class="flex items-baseline justify-between mb-2">
      <h3 class="text-[#482A32] font-normal text-sm">{title}</h3>
      <span class="text-[#482A32] text-[11px] ml-6 shrink-0 border border-[#36151E] px-2 py-0.5 rounded-sm">
        Coming soon
      </span>
    </div>
    <p class="text-[#482A32] text-xs leading-relaxed">{description}</p>
  </div>
) : (
  <a
    href={`/projects/${slug}`}
    class="group block border-t border-[#1e1e1e] py-7 hover:border-[#2a2a2a] transition-colors duration-200"
  >
    <div class="flex items-baseline justify-between mb-2">
      <h3 class="text-[#EFF1F3] font-normal text-sm group-hover:text-white transition-colors duration-200">
        {title}
      </h3>
      <span class="text-[#95757F] text-xs ml-6 shrink-0 tabular-nums">{year}</span>
    </div>
    <p class="text-[#525252] text-xs leading-relaxed mb-4">{description}</p>
    <div class="flex gap-1.5 flex-wrap">
      {tags.map((tag) => (
        <span class="text-[#95757F] text-[11px] border border-[#1e1e1e] px-2 py-0.5 rounded-sm group-hover:border-[#482A32] transition-colors duration-200">
          {tag}
        </span>
      ))}
    </div>
  </a>
)}
