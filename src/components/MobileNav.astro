---
const currentPath = Astro.url.pathname;
const isHome        = currentPath === '/';
const isProjects    = currentPath.startsWith('/projects');
const isCheatsheets = currentPath.startsWith('/cheatsheets');
const isCaseStudy   = currentPath.startsWith('/case-studies');
const isLog         = currentPath.startsWith('/log');

const links = [
  { href: '/',            label: 'home',        active: isHome        },
  { href: '/projects',    label: 'projects',    active: isProjects    },
  { href: '/cheatsheets', label: 'cheatsheets', active: isCheatsheets },
  { href: '/log',         label: 'log',         active: isLog         },
];
---

<div id="mobile-nav" class="mobile-nav-wrap">
  <!-- Overlay backdrop -->
  <div id="mobile-nav-backdrop" class="mobile-backdrop"></div>

  <!-- Panel -->
  <div id="mobile-nav-panel" class="mobile-panel">
    {links.map(link => (
      link.active ? (
        <span class="mobile-link active" aria-current="page">{link.label}</span>
      ) : (
        <a href={link.href} class="mobile-link">{link.label}</a>
      )
    ))}
  </div>

  <!-- Toggle button -->
  <button id="mobile-nav-toggle" class="mobile-toggle" aria-label="Toggle navigation" aria-expanded="false" aria-controls="mobile-nav-panel">
    <span class="toggle-icon open-icon">
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
        <rect x="1.5" y="2.5" width="11" height="1.4" rx="0.7" fill="currentColor"/>
        <rect x="1.5" y="6.3" width="11" height="1.4" rx="0.7" fill="currentColor"/>
        <rect x="1.5" y="10.1" width="11" height="1.4" rx="0.7" fill="currentColor"/>
      </svg>
    </span>
    <span class="toggle-icon close-icon" style="display:none;">
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M2.5 2.5L11.5 11.5M11.5 2.5L2.5 11.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
      </svg>
    </span>
  </button>
</div>

<style>
  .mobile-nav-wrap {
    display: none;
  }

  @media (max-width: 768px) {
    .mobile-nav-wrap {
      display: block;
    }

    .mobile-backdrop {
      display: none;
      position: fixed;
      inset: 0;
      z-index: 20;
    }

    .mobile-panel {
      position: fixed;
      bottom: 5rem;
      right: 1.25rem;
      z-index: 30;
      display: flex;
      flex-direction: column;
      align-items: flex-end;
      gap: 0.25rem;
      opacity: 0;
      pointer-events: none;
      transform: translateY(8px);
      transition: opacity 0.2s ease, transform 0.2s ease;
    }

    .mobile-panel.open {
      opacity: 1;
      pointer-events: auto;
      transform: translateY(0);
    }

    .mobile-link {
      font-family: var(--font-display);
      font-size: 13px;
      letter-spacing: 0.08em;
      padding: 0.5rem 1rem;
      border-radius: 4px;
      background: var(--bg);
      border: 1px solid var(--border);
      color: var(--text-3);
      text-decoration: none;
      transition: color 0.2s ease, border-color 0.2s ease;
      white-space: nowrap;
    }

    .mobile-link.active {
      color: var(--accent);
      border-color: var(--accent-d);
      cursor: default;
    }

    .mobile-link:not(.active):hover {
      color: var(--accent);
      border-color: var(--border-h);
    }

    .mobile-toggle {
      position: fixed;
      bottom: 1.25rem;
      right: 1.25rem;
      z-index: 40;
      width: 42px;
      height: 42px;
      border-radius: 4px;
      background: var(--bg);
      border: 1px solid var(--border);
      color: var(--text-2);
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      transition: color 0.2s ease, border-color 0.2s ease;
    }

    .mobile-toggle:hover {
      color: var(--accent);
      border-color: var(--border-h);
    }

    .toggle-icon {
      display: flex;
      align-items: center;
      justify-content: center;
    }
  }
</style>

<script>
  document.addEventListener('astro:page-load', () => {
    const toggle    = document.getElementById('mobile-nav-toggle');
    const panel     = document.getElementById('mobile-nav-panel');
    const backdrop  = document.getElementById('mobile-nav-backdrop');
    const openIcon  = toggle?.querySelector('.open-icon') as HTMLElement | null;
    const closeIcon = toggle?.querySelector('.close-icon') as HTMLElement | null;
    if (!toggle || !panel || !backdrop) return;

    let open = false;

    const panelLinks = panel.querySelectorAll<HTMLElement>('a');

    function openMenu() {
      open = true;
      panel.classList.add('open');
      backdrop.style.display = 'block';
      toggle.setAttribute('aria-expanded', 'true');
      panelLinks.forEach(l => l.removeAttribute('tabindex'));
      if (openIcon)  openIcon.style.display  = 'none';
      if (closeIcon) closeIcon.style.display = 'flex';
    }

    function closeMenu() {
      open = false;
      panel.classList.remove('open');
      backdrop.style.display = 'none';
      toggle.setAttribute('aria-expanded', 'false');
      panelLinks.forEach(l => l.setAttribute('tabindex', '-1'));
      if (openIcon)  openIcon.style.display  = 'flex';
      if (closeIcon) closeIcon.style.display = 'none';
    }

    // Initially hide links from tab order
    panelLinks.forEach(l => l.setAttribute('tabindex', '-1'));

    toggle.addEventListener('click', () => open ? closeMenu() : openMenu());
    backdrop.addEventListener('click', closeMenu);
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && open) { closeMenu(); toggle.focus(); }
    });
  });
</script>
