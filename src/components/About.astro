---
const name = 'Nataša Minić';
const role = 'Web Developer';
---

<section>
  <h1 class="text-[clamp(28px,4.5vw,40px)] font-light tracking-tight leading-[1.2] mb-8 about-enter" style="color: var(--text-1);">hey, i'm naca.<br /><span class="text-[0.6em]">i build things for the web.</span></h1>

  <div id="bio-wrapper" class="py-2">
    <div id="rotating-phrase" class="h-6 overflow-hidden text-base mb-4" aria-hidden="true" style="color: var(--text-3);"></div>
    <p class="text-[18px] leading-relaxed" style="color: var(--text-2);">
      detail-obsessed, results-driven and genuinely interested in performance. web metrics, personal growth, all of it. small things compound, so i take them seriously. i also maintain one (1) cat.<!--
      --><svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline;vertical-align:-1px;margin-left:3px;opacity:0.7;"><path d="M12 5c.67 0 1.35.09 2 .26 1.78-2 5.03-2.84 6.42-2.26 1.4.58-.42 7-.42 7 .57 1.07 1 2.24 1 3.44C21 17.9 16.97 21 12 21s-9-3-9-7.56c0-1.25.5-2.4 1-3.44 0 0-1.89-6.42-.5-7 1.39-.58 4.72.23 6.5 2.26A9.06 9.06 0 0 1 12 5Z"/><path d="M8 14v.5"/><path d="M16 14v.5"/><path d="M11.25 16.25h1.5L12 17l-.75-.75Z"/></svg>
      she ships no features but consistently breaks builds by walking on the keyboard. <a href="/projects" class="link-accent">the work</a> ships anyway. i made <a href="/cheatsheets" class="link-accent">cheatsheets</a> to stay ahead of the damage. it works. she does not care.
    </p>
    <p class="text-[15px] leading-relaxed mt-6" style="color: var(--text-3);">
      by day, developer at <a href="https://usablenet.com/" target="_blank" rel="noopener noreferrer" class="link-accent">usablenet</a>, sitting at the intersection of quality and code to make the web accessible to everyone. previously, <a href="https://wowa.rs/" target="_blank" rel="noopener noreferrer" class="link-accent">wowa</a> (wordpress, agency work) and <a href="https://www.linkedin.com/company/sellers-alley/" target="_blank" rel="noopener noreferrer" class="link-accent">sellers alley</a> (laravel, internal hr app). every job taught me something the next one needed.
    </p>
  </div>
</section>

<style>
  .about-enter {
    opacity: 0;
    transform: translateY(16px);
    transition: opacity 0.6s ease, transform 0.6s ease;
  }
  .about-enter.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  @media (max-width: 768px) {
    .about-enter {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }
</style>

<script>
  document.addEventListener('astro:page-load', () => {
    const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    // h1 entrance
    document.querySelectorAll<HTMLElement>('.about-enter').forEach(el => {
      if (reducedMotion) { el.classList.add('is-visible'); return; }
      setTimeout(() => el.classList.add('is-visible'), 0);
    });

    // ── A: Rotating phrase — blur focus pull ──────────────────────────
    const container = document.getElementById('rotating-phrase');
    if (!container) return;

    const phrases = [
      'i care about the details. a lot.',
      'things should just work. i make sure they do.',
      'obsessed with quality. allergic to shortcuts.',
      'ships things. on time.',
    ];

    let currentIndex = 0;

    if (reducedMotion) {
      container.style.opacity = '1';
    } else {
      container.style.opacity = '0';
      container.style.filter = 'blur(8px)';
      container.style.transition = 'opacity 0.5s ease, filter 0.5s ease';
    }

    function makeSpans(text: string): HTMLSpanElement[] {
      return text.split('').map(char => {
        const span = document.createElement('span');
        span.textContent = char;
        span.style.display = 'inline-block';
        span.style.whiteSpace = char === ' ' ? 'pre' : 'normal';
        span.style.opacity = '0';
        span.style.filter = 'blur(4px)';
        span.style.transform = 'translateY(-10px)';
        span.style.transition = 'opacity 0.4s ease, filter 0.4s ease, transform 0.4s ease';
        return span;
      });
    }

    function animateIn(spans: HTMLSpanElement[]) {
      spans.forEach((span, i) => {
        setTimeout(() => {
          span.style.opacity = '1';
          span.style.filter = 'blur(0px)';
          span.style.transform = 'translateY(0px)';
        }, i * 25);
      });
    }

    function animateOut(spans: HTMLSpanElement[], onDone: () => void) {
      spans.forEach((span, i) => {
        setTimeout(() => {
          span.style.opacity = '0';
          span.style.filter = 'blur(4px)';
          span.style.transform = 'translateY(10px)';
        }, i * 15);
      });
      setTimeout(onDone, spans.length * 15 + 450);
    }

    function showPhrase(index: number, first = false) {
      if (reducedMotion) {
        container.textContent = phrases[index];
        container.style.opacity = '1';
        setTimeout(() => {
          currentIndex = (currentIndex + 1) % phrases.length;
          showPhrase(currentIndex);
        }, 3500);
        return;
      }

      container.innerHTML = '';
      const spans = makeSpans(phrases[index]);
      spans.forEach(s => container.appendChild(s));

      requestAnimationFrame(() => {
        requestAnimationFrame(() => {
          if (first) {
            container.style.opacity = '1';
            container.style.filter = 'blur(0px)';
          }
          animateIn(spans);
        });
      });

      const inDuration = phrases[index].length * 25 + 400;
      setTimeout(() => {
        animateOut(spans, () => {
          currentIndex = (currentIndex + 1) % phrases.length;
          showPhrase(currentIndex);
        });
      }, inDuration + 3000);
    }

    setTimeout(() => showPhrase(0, true), reducedMotion ? 0 : 200);

  });
</script>
