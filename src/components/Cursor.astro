---
---
<div id="cursor-dot" aria-hidden="true" transition:persist></div>
<div id="cursor-ring" aria-hidden="true" transition:persist></div>

<style is:global>
  @media (hover: hover) and (pointer: fine) {
    html, html * { cursor: none !important; }
  }

  #cursor-dot,
  #cursor-ring {
    position: fixed;
    border-radius: 50%;
    pointer-events: none;
    transform: translate(-50%, -50%);
    opacity: 0;
    z-index: 10000;
  }

  #cursor-dot {
    width: 5px;
    height: 5px;
    background: var(--accent);
    z-index: 10001;
    transition: width 0.2s ease, height 0.2s ease, opacity 0.4s ease;
  }

  #cursor-ring {
    width: 30px;
    height: 30px;
    border: 1.5px solid var(--accent);
    transition: width 0.25s ease, height 0.25s ease, border-color 0.25s ease, opacity 0.4s ease;
  }

  #cursor-dot.is-active  { opacity: 1; }
  #cursor-ring.is-active { opacity: 0.4; }

  body.is-hovering #cursor-ring {
    width: 48px;
    height: 48px;
    opacity: 0.65;
  }
  body.is-hovering #cursor-dot {
    width: 3px;
    height: 3px;
  }

  @media not all and (hover: hover) {
    #cursor-dot, #cursor-ring { display: none; }
  }
</style>

<script>
  let started = false;
  let mouseX = -200, mouseY = -200;
  let ringX  = -200, ringY  = -200;

  function initCursor() {
    const dot  = document.getElementById('cursor-dot');
    const ring = document.getElementById('cursor-ring');
    if (!dot || !ring) return;

    if (!window.matchMedia('(hover: hover) and (pointer: fine)').matches) return;

    if (!started) {
      started = true;

      document.addEventListener('mousemove', (e) => {
        mouseX = e.clientX;
        mouseY = e.clientY;
        dot.style.left = mouseX + 'px';
        dot.style.top  = mouseY + 'px';
        dot.classList.add('is-active');
        ring.classList.add('is-active');
      });

      (function tick() {
        ringX += (mouseX - ringX) * 0.1;
        ringY += (mouseY - ringY) * 0.1;
        ring.style.left = ringX + 'px';
        ring.style.top  = ringY + 'px';
        requestAnimationFrame(tick);
      })();
    }

    document.body.classList.remove('is-hovering');
    document.querySelectorAll('a, button, [role="button"]').forEach(el => {
      el.addEventListener('mouseenter', () => document.body.classList.add('is-hovering'));
      el.addEventListener('mouseleave', () => document.body.classList.remove('is-hovering'));
    });
  }

  document.addEventListener('astro:page-load', initCursor);
</script>
