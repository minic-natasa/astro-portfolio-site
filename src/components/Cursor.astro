---
<div id="cursor-dot" aria-hidden="true" transition:persist></div>

<style is:global>
  @media (hover: hover) and (pointer: fine) {
    html, html * { cursor: none !important; }
  }

  #cursor-dot {
    position: fixed;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--accent);
    pointer-events: none;
    z-index: 10000;
    top: 0;
    left: 0;
    transform: translate(-50%, -50%);
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  #cursor-dot.is-active { opacity: 1; }

  @media not all and (hover: hover) {
    #cursor-dot { display: none; }
  }
</style>

<script>
  let started = false;

  function initCursor() {
    const dot = document.getElementById('cursor-dot') as HTMLElement | null;
    if (!dot) return;
    if (!window.matchMedia('(hover: hover) and (pointer: fine)').matches) return;

    if (!started) {
      started = true;
      document.addEventListener('mousemove', (e) => {
        dot.style.transform = `translate(calc(${e.clientX}px - 50%), calc(${e.clientY}px - 50%))`;
        dot.classList.add('is-active');
      });
    }
  }

  document.addEventListener('astro:page-load', initCursor);
</script>
