---
import DemoPanel from './DemoPanel.astro';

const buckets = [
  { name: 'base', min: 0 },
  { name: 'sm', min: 640 },
  { name: 'md', min: 768 },
  { name: 'lg', min: 1024 },
  { name: 'xl', min: 1280 },
  { name: '2xl', min: 1536 },
];
---

<DemoPanel label="live readout">
  <div data-demo="media" class="mq">

    <div class="demo-row">
      <span class="demo-row-label">viewport</span>
      <span class="mq-chips">
        {buckets.map(b => (
          <span class="demo-pill mq-chip" data-min={b.min}>{b.name}</span>
        ))}
      </span>
      <span class="mq-width"></span>
    </div>

    <div class="demo-readout mq-prefs" aria-live="off"></div>

    <p class="mq-note">resize the window and watch the chips move. the rest comes from your system settings.</p>
  </div>
</DemoPanel>

<style>
  .mq-chips {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
  }
  .mq-chip { cursor: default; }
  .mq-width {
    font-family: ui-monospace, 'Menlo', monospace;
    font-size: 12px;
    color: var(--accent);
  }
  .mq-note {
    font-size: 12px;
    color: var(--text-3);
    margin-top: 0.8rem;
  }
</style>

<script>
  document.addEventListener('astro:page-load', () => {
    const root = document.querySelector<HTMLElement>('[data-demo="media"]');
    if (!root) return;
    const chips = root.querySelectorAll<HTMLElement>('.mq-chip');
    const widthEl = root.querySelector<HTMLElement>('.mq-width');
    const prefs = root.querySelector<HTMLElement>('.mq-prefs');

    const queries = {
      dark:    matchMedia('(prefers-color-scheme: dark)'),
      motion:  matchMedia('(prefers-reduced-motion: reduce)'),
      hover:   matchMedia('(hover: hover)'),
    };

    function update() {
      const w = window.innerWidth;
      let active: HTMLElement | null = null;
      chips.forEach(chip => {
        chip.removeAttribute('data-active');
        if (w >= Number(chip.dataset.min)) active = chip;
      });
      active?.setAttribute('data-active', '');
      if (widthEl) widthEl.textContent = `${w}px`;
      if (prefs) {
        prefs.textContent =
          `prefers-color-scheme:   ${queries.dark.matches ? 'dark' : 'light'}\n` +
          `prefers-reduced-motion: ${queries.motion.matches ? 'reduce' : 'no-preference'}\n` +
          `(hover: hover):         ${queries.hover.matches ? 'true — mouse-ish' : 'false — touch-ish'}`;
      }
    }

    window.addEventListener('resize', update, { passive: true });
    Object.values(queries).forEach(q => q.addEventListener('change', update));
    update();
  });
</script>
