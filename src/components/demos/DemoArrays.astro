---
import DemoPanel from './DemoPanel.astro';
---

<DemoPanel>
  <div data-demo="arrays">
    <div class="demo-row">
      <span class="demo-row-label">source</span>
      <span class="ar-source">[1, 2, 3, 4, 5]</span>
    </div>
    <div class="demo-row">
      <span class="demo-row-label">method</span>
      <button class="demo-pill" data-op="map" data-active aria-pressed="true">map ×2</button>
      <button class="demo-pill" data-op="filter" aria-pressed="false">filter &gt;2</button>
      <button class="demo-pill" data-op="reduce" aria-pressed="false">reduce +</button>
      <button class="demo-pill" data-op="find" aria-pressed="false">find &gt;3</button>
      <button class="demo-pill" data-op="some" aria-pressed="false">some &gt;4</button>
      <button class="demo-pill" data-op="every" aria-pressed="false">every &gt;0</button>
    </div>

    <div class="demo-readout ar-readout" aria-live="polite"></div>
  </div>
</DemoPanel>

<style>
  .ar-source {
    font-family: ui-monospace, 'Menlo', monospace;
    font-size: 12px;
    color: var(--text-2);
  }
</style>

<script>
  document.addEventListener('astro:page-load', () => {
    const root = document.querySelector<HTMLElement>('[data-demo="arrays"]');
    if (!root) return;
    const readout = root.querySelector<HTMLElement>('.ar-readout');
    if (!readout) return;

    const source = [1, 2, 3, 4, 5];
    const ops: Record<string, { expr: string; run: (a: number[]) => unknown }> = {
      map:    { expr: '.map(n => n * 2)',              run: a => a.map(n => n * 2) },
      filter: { expr: '.filter(n => n > 2)',           run: a => a.filter(n => n > 2) },
      reduce: { expr: '.reduce((acc, n) => acc + n, 0)', run: a => a.reduce((acc, n) => acc + n, 0) },
      find:   { expr: '.find(n => n > 3)',             run: a => a.find(n => n > 3) },
      some:   { expr: '.some(n => n > 4)',             run: a => a.some(n => n > 4) },
      every:  { expr: '.every(n => n > 0)',            run: a => a.every(n => n > 0) },
    };

    function fmt(v: unknown): string {
      return Array.isArray(v) ? `[${v.join(', ')}]` : String(v);
    }

    function show(op: string) {
      const def = ops[op];
      if (!def) return;
      readout!.textContent = `[1, 2, 3, 4, 5]${def.expr}\n→ ${fmt(def.run(source))}`;
    }

    root.querySelectorAll<HTMLButtonElement>('.demo-pill[data-op]').forEach(btn => {
      btn.addEventListener('click', () => {
        root.querySelectorAll('.demo-pill').forEach(b => {
          b.removeAttribute('data-active');
          b.setAttribute('aria-pressed', 'false');
        });
        btn.setAttribute('data-active', '');
        btn.setAttribute('aria-pressed', 'true');
        show(btn.dataset.op ?? 'map');
      });
    });

    show('map');
  });
</script>
