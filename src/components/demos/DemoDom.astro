---
import DemoPanel from './DemoPanel.astro';
---

<DemoPanel>
  <div data-demo="dom">
    <div class="demo-stage">
      <div class="dom-el" aria-hidden="true">
        <span class="dom-el-label">el</span>
      </div>
    </div>

    <div class="demo-row">
      <span class="demo-row-label">run</span>
      <button class="demo-pill dom-toggle">classList.toggle('active')</button>
      <button class="demo-pill dom-append">createElement + append</button>
      <button class="demo-pill dom-remove">lastElementChild.remove()</button>
    </div>

    <div class="demo-readout dom-readout" aria-live="polite"></div>
  </div>
</DemoPanel>

<style>
  .dom-el {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    flex-wrap: wrap;
    min-height: 52px;
    border: 1px solid var(--border-h);
    border-radius: 4px;
    padding: 0.6rem 0.8rem;
    transition: border-color 0.25s ease, background 0.25s ease;
  }
  .dom-el.active {
    border-color: var(--accent);
    background: var(--accent-d);
  }
  .dom-el-label {
    font-family: ui-monospace, 'Menlo', monospace;
    font-size: 11px;
    color: var(--text-3);
  }
  .dom-el :global(.dom-cat) {
    display: inline-flex;
    color: var(--accent);
    line-height: 0;
  }
</style>

<script>
  document.addEventListener('astro:page-load', () => {
    const root = document.querySelector<HTMLElement>('[data-demo="dom"]');
    if (!root) return;
    const el = root.querySelector<HTMLElement>('.dom-el');
    const readout = root.querySelector<HTMLElement>('.dom-readout');
    if (!el || !readout) return;

    const CAT_SVG =
      '<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5c.67 0 1.35.09 2 .26 1.78-2 5.03-2.84 6.42-2.26 1.4.58-.42 7-.42 7 .57 1.07 1 2.24 1 3.44C21 17.9 16.97 21 12 21s-9-3-9-7.56c0-1.25.5-2.4 1-3.44 0 0-1.89-6.42-.5-7 1.39-.58 4.72.23 6.5 2.26A9.06 9.06 0 0 1 12 5Z"/><path d="M8 14v.5"/><path d="M16 14v.5"/><path d="M11.25 16.25h1.5L12 17l-.75-.75Z"/></svg>';

    const cats = () => el!.querySelectorAll('.dom-cat').length;

    function report(line: string) {
      readout!.textContent =
        `${line}\n` +
        `el.className → "${el!.className}"   cats → ${cats()}`;
    }

    root.querySelector('.dom-toggle')?.addEventListener('click', () => {
      el.classList.toggle('active');
      report(`el.classList.toggle('active');`);
    });

    root.querySelector('.dom-append')?.addEventListener('click', () => {
      if (cats() >= 10) {
        report(`// that's enough cats. she agrees.`);
        return;
      }
      const cat = document.createElement('span');
      cat.className = 'dom-cat';
      cat.innerHTML = CAT_SVG;
      el.appendChild(cat);
      report(`const cat = document.createElement('span'); el.appendChild(cat);`);
    });

    root.querySelector('.dom-remove')?.addEventListener('click', () => {
      const last = el.querySelector('.dom-cat:last-of-type');
      if (last) {
        last.remove();
        report(`el.lastElementChild.remove();`);
      } else {
        report(`// nothing left to remove. the div is at peace.`);
      }
    });

    report('// click something. the element reacts, the state prints here.');
  });
</script>
