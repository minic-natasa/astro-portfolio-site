---
import DemoPanel from './DemoPanel.astro';
---

<DemoPanel>
  <div data-demo="center">
    <div class="demo-stage c-stage m-flex" aria-hidden="true">
      <span class="c-dot"></span>
    </div>
    <div class="demo-row">
      <span class="demo-row-label">method</span>
      <button class="demo-pill" data-method="m-flex" data-active aria-pressed="true">flex</button>
      <button class="demo-pill" data-method="m-grid" aria-pressed="false">grid</button>
      <button class="demo-pill" data-method="m-abs" aria-pressed="false">absolute</button>
    </div>
    <p class="c-note">the dot does not care which method you pick. that's the point.</p>
  </div>
</DemoPanel>

<style>
  .c-stage { height: 110px; }
  .c-dot {
    width: 18px;
    height: 18px;
    border-radius: 50%;
    background: var(--accent);
    display: block;
  }
  .c-stage.m-flex { display: flex; align-items: center; justify-content: center; }
  .c-stage.m-grid { display: grid; place-items: center; }
  .c-stage.m-abs  { position: relative; display: block; }
  .c-stage.m-abs .c-dot {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
  }
  .c-note {
    font-size: 12px;
    color: var(--text-3);
    margin-top: 0.8rem;
  }
</style>

<script>
  document.addEventListener('astro:page-load', () => {
    const root = document.querySelector<HTMLElement>('[data-demo="center"]');
    if (!root) return;
    const stage = root.querySelector<HTMLElement>('.c-stage');
    if (!stage) return;

    root.querySelectorAll<HTMLButtonElement>('.demo-pill').forEach(btn => {
      btn.addEventListener('click', () => {
        root.querySelectorAll('.demo-pill').forEach(b => {
          b.removeAttribute('data-active');
          b.setAttribute('aria-pressed', 'false');
        });
        btn.setAttribute('data-active', '');
        btn.setAttribute('aria-pressed', 'true');
        stage.classList.remove('m-flex', 'm-grid', 'm-abs');
        stage.classList.add(btn.dataset.method ?? 'm-flex');
      });
    });
  });
</script>
