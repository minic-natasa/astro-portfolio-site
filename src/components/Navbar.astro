---
const currentPath = Astro.url.pathname;
const isHome        = currentPath === '/';
const isProjects    = currentPath.startsWith('/projects');
const isCheatsheets = currentPath.startsWith('/cheatsheets');
const isCaseStudy   = currentPath.startsWith('/case-studies');
const isLog         = currentPath.startsWith('/log');

const navItems = [
  { href: '/',            label: 'home',        active: isHome        },
  { href: '/projects',    label: 'projects',    active: isProjects    },
  { href: '/cheatsheets', label: 'cheatsheets', active: isCheatsheets },
];
---

<nav class="max-w-2xl mx-auto px-6 py-4 md:py-8 flex items-center justify-between w-full">

  <!-- Theme toggle -->
  <button
    id="theme-toggle"
    aria-label="Toggle theme"
    class="transition-colors duration-200"
    style="color: var(--accent);"
  >
    <svg id="icon-sun" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="12" cy="12" r="4"/>
      <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/>
    </svg>
    <svg id="icon-moon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
    </svg>
  </button>

  <!-- Nav links -->
  <div class="flex items-center gap-5" style={(isHome || isProjects || isCheatsheets || isCaseStudy || isLog) ? 'display:none' : ''}>
    {navItems.map((item, i) => (
      item.active ? (
        <span
          class="nav-item"
          data-index={i}
          aria-current="page"
          style="font-family: var(--font-display); font-size: 16px; color: var(--accent); opacity: 0;"
        >{item.label}</span>
      ) : (
        <a
          href={item.href}
          class="nav-item nav-link"
          data-index={i}
          style="font-family: var(--font-display); font-size: 16px; opacity: 0;"
        >{item.label}</a>
      )
    ))}
  </div>

</nav>

<style>
  .nav-link {
    color: var(--text-3);
    transition: color 0.2s ease;
  }
  .nav-link:hover,
  .nav-link:focus-visible {
    color: var(--accent-h);
  }
</style>

<script>
  function updateIcon() {
    const isDark = document.documentElement.classList.contains('dark');
    const sun  = document.getElementById('icon-sun');
    const moon = document.getElementById('icon-moon');
    if (!sun || !moon) return;
    sun.style.display  = isDark ? 'block' : 'none';
    moon.style.display = isDark ? 'none'  : 'block';
  }

  let switchTimer: ReturnType<typeof setTimeout> | undefined;

  function setThemeColorMeta(doc: Document, theme: string) {
    const tc = doc.querySelector('meta[name="theme-color"]');
    if (tc) tc.setAttribute('content', theme === 'dark' ? '#181818' : '#F7F6F6');
  }

  function initThemeToggle() {
    const btn = document.getElementById('theme-toggle');
    if (!btn) return;
    updateIcon();
    btn.addEventListener('click', () => {
      const isDark = document.documentElement.classList.contains('dark');
      const next = isDark ? 'light' : 'dark';
      // enable the global cross-fade only for the duration of the switch
      document.documentElement.classList.add('theme-switching');
      clearTimeout(switchTimer);
      switchTimer = setTimeout(() => document.documentElement.classList.remove('theme-switching'), 450);
      document.documentElement.classList.remove('dark', 'light');
      document.documentElement.classList.add(next);
      localStorage.setItem('theme', next);
      setThemeColorMeta(document, next);
      updateIcon();
    });
  }

  function initNavAnimation() {
    const items = document.querySelectorAll<HTMLElement>('.nav-item');
    items.forEach((item, i) => {
      item.style.opacity   = '0';
      item.style.transform = 'translateX(8px)';
      item.style.transition = 'opacity 0.3s ease, transform 0.3s ease, color 0.2s ease';

      setTimeout(() => {
        item.style.opacity   = '1';
        item.style.transform = 'translateX(0)';
      }, i * 60);
    });
  }

  document.addEventListener('astro:before-swap', (e) => {
    const theme = localStorage.getItem('theme') ?? 'dark';
    const newDoc = (e as any).newDocument as Document;
    newDoc.documentElement.classList.remove('dark', 'light');
    newDoc.documentElement.classList.add(theme);
    setThemeColorMeta(newDoc, theme);
  });

  document.addEventListener('astro:page-load', () => {
    initThemeToggle();
    initNavAnimation();
  });
</script>
